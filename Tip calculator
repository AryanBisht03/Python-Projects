print("Welcome to the tip calculator.")
total_bill=input("What was the total bill? $")
tip=input("What percentage tip would you like to give? 10, 12, or 15?")
total_person=input("How many people to split the bill?")
percentage=float(total_bill)*(int(tip)/100)
after_split=(percentage+float(total_bill))/int(total_person)
a=round(after_split,2)
print("Each person should pay:"+str(a))
